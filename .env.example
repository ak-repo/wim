# PostgreSQL
POSTGRES_USER=wim_user
POSTGRES_PASSWORD=wim_pass
POSTGRES_DB=warehouse_inventory
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# Kafka
KAFKA_PORT=9092
KAFKA_CONTAINER_NAME=kafka

# Application (for reference)
DATABASE_URL=postgres://wim_user:wim_pass@localhost:5432/warehouse_inventory?sslmode=disable

AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_ISSUER=wim
AUTH_ACCESS_TOKEN_TTL=168h
AUTH_REFRESH_TOKEN_TTL=720h

REDIS_HOST=localhost
REDIS_DB=0

KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=warehouse-events
KAFKA_GROUP_ID=warehouse-worker

SERVER_HOST=0.0.0.0
SERVER_PORT=8090
LOG_LEVEL=info