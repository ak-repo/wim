# ======================
# DATABASE (REQUIRED)
# ======================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=wim_user
POSTGRES_PASSWORD=wim_pass
POSTGRES_DB=warehouse_inventory
DATABASE_MAX_CONNS=25
DATABASE_URL=postgres://wim_user:wim_pass@localhost:5432/warehouse_inventory?sslmode=disable

# ======================
# REDIS (REQUIRED)
# ======================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=wim_redis_pass
REDIS_DB=0

# ======================
# AUTH (REQUIRED)
# ======================
AUTH_JWT_SECRET=change-me
AUTH_JWT_ISSUER=wim

# ======================
# OPTIONAL OVERRIDES
# ======================
SERVER_HOST=0.0.0.0
SERVER_PORT=8090
SERVER_URL=http://localhost:8090
LOG_LEVEL=info